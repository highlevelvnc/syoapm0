# Supabase — copia do dashboard do projecto (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# server-only — NUNCA expor com NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# URL pública da app (sem trailing slash)
# Local: http://localhost:3000
# Production: https://blindai.vercel.app ou domínio próprio
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sal para hash de IPs no consent log (gera com: openssl rand -hex 32)
IP_HASH_SALT=change-me-with-openssl-rand-hex-32
