# Supabase — copia do dashboard do projecto (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# server-only — NUNCA expor com NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# URL pública da app (sem trailing slash)
# Local: http://localhost:3000
# Production: https://blindai.vercel.app ou domínio próprio
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sal para hash de IPs no consent log (gera com: openssl rand -hex 32)
IP_HASH_SALT=change-me-with-openssl-rand-hex-32

# Token Bearer para proteger o cron job de scan diário (gera com: openssl rand -hex 32).
# No Vercel, define como env var e o Vercel Cron envia no header Authorization automaticamente.
CRON_SECRET=change-me-with-openssl-rand-hex-32

# Chave AES-256-GCM (32 bytes hex = 64 chars) para encriptar tokens Cloudflare e
# similares guardados na DB. Gera com: openssl rand -hex 32
# IMPORTANTE: se mudares esta chave, todos os tokens guardados ficam ilegíveis.
ENCRYPTION_KEY=change-me-with-openssl-rand-hex-32
